{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        {
          "url": "https://api.bilibili.com/*"
        },
        {
          "url": "https://www.bilibili.com/*"
        },
        {
          "url": "https://api.allorigins.win/*"
        }
      ]
    }
  ]
}
